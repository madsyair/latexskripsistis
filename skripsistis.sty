\newcommand{\skPeminatan}{}     \newcommand{\peminatan}[1]{\renewcommand{\skPeminatan}{#1}}
\newcommand{\skTahun}{}         \newcommand{\tahunskripsi}[1]{\renewcommand{\skTahun}{#1}}
\newcommand{\skTglSidang}{[tanggal sidang]}\newcommand{\tglsidang}[1]{\renewcommand{\skTglSidang}{#1}}
